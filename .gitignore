# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build and packaging artifacts
build/
dist/
*.egg-info/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# Local runtime data
var/cache/
var/downloads/
var/logs/
var/tmp/

# Local trust material that may be managed separately
# Uncomment if you do not want to version local keyrings/fingerprint policy
# trust/ubuntu/keyrings/*.gpg
# trust/ubuntu/fingerprints/*.txt

# OS-specific files
.DS_Store
Thumbs.db

# Test and coverage artifacts
.pytest_cache/
.coverage
htmlcov/
